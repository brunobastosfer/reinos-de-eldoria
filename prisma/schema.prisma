// ======================================================
// PRISMA CONFIG
// ======================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================================
// ENUMS
// ======================================================

enum AccountStatus {
  BANISHED
  SUSPEND
  NORMAL
}

enum TypeSkillBenefity {
  SHIELD_INCREASE
  ATTACK_INCREASE
  LIFE_DRAIN
  MANA_DRAIN
}

enum AccountType {
  FREE
  PREMIUM
}

enum ClasseType {
  KNIGHT
  MAGE
  HEALER
  ARCHER
}

enum SkillUtilityType {
  STUN
  SNARE
  FEAR
  BUFF
  DBUFF
}

enum skillType {
  ATACK
  DEFENSE
  HEAL
}

enum Attribute {
  DISTANCE
  SWORD
  MAGIC
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum BoostType {
  EXPERIENCE
  TRAINER
  LUCKY
}

enum CharacterStatus {
  BLOCKED
  BANISHED
  TRAINING
  TRAVELING
  IN_MISSION
}

enum ItemType {
  LEG
  ARMOR
  WEAPON
  SHIELD
  HELMET
  AMULET
  RING
  BOOTS
  CONSUMABLE
}

// ======================================================
// USER / ACCOUNT
// ======================================================

model User {
  id          String    @id @default(uuid())
  name        String
  email       String
  password    String
  age         Int
  nacionality String
  confirmed   Boolean
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  account Account? @relation("UserAccount")

  @@map("users")
}

model Account {
  id            String             @id @default(uuid())
  accountStatus AccountStatus      @default(NORMAL) @map("account_status")
  accountType   AccountType        @default(FREE) @map("account_type")
  userId        String             @unique
  user          User               @relation("UserAccount", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  characters    Character[]
  premium       PremiumToAccount[]
  isAdmin       Boolean            @default(false)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")

  @@map("accounts")
}

model PremiumAccount {
  id      String             @id @default(uuid())
  days    Int
  price   Float
  account PremiumToAccount[]

  @@map("premium_account")
}

model PremiumToAccount {
  id             String         @id @default(uuid())
  activatedAt    DateTime       @map("activated_at")
  expiratedAt    DateTime       @map("expirated_at")
  accountId      String
  premiumId      String
  premiumAccount PremiumAccount @relation(fields: [premiumId], references: [id])
  account        Account        @relation(fields: [accountId], references: [id])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  @@map("premium_to_account")
}

// ======================================================
// CLASSES / SKILLS
// ======================================================

model Classe {
  id          String      @id @default(uuid())
  type        ClasseType
  manaBase    Int         @map("mana_base")
  lifeBase    Int         @map("life_base")
  damageBase  Int         @map("damage_base")
  defenseBase Int         @map("defense_base")
  attribute   Attribute
  skill       Skill[]
  character   Character[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  @@map("classes")
}

model Skill {
  id              String            @id @default(uuid())
  name            String
  description     String
  mana            Int
  type            skillType
  utility         SkillUtilityType?
  skillScaling    Float             @default(0.5)
  classeId        String?           @map("class_id")
  skillValueId    String            @map("skill_value_id")
  skillBenefityId String?           @map("skill_benefity_id")

  skillBenefity SkillBenefity? @relation(fields: [skillBenefityId], references: [id])
  Classe        Classe?        @relation(fields: [classeId], references: [id])
  value         SkillValue     @relation(fields: [skillValueId], references: [id])
  Monster       Monster?       @relation(fields: [monsterId], references: [id])
  monsterId     String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("skills")
}

model SkillBenefity {
  id    String            @id @default(uuid())
  value Int
  type  TypeSkillBenefity
  Skill Skill[]

  @@map("skill_benefities")
}

model MonsterBattle {
  id String @id @default(uuid())

  characterId String
  monsterId   String

  characterCurrentLife Int
  characterMaxLife     Int

  monsterCurrentLife Int
  monsterMaxLife     Int

  fleeAttempted Boolean @default(false)
  fleeLocked    Boolean @default(false)

  winner String? // CHARACTER | MONSTER | FLEE

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  finishedAt DateTime?

  @@index([characterId])
  @@index([monsterId])
  @@index([characterId, finishedAt])
  @@map("monster_battles")
}

model SkillValue {
  id    String  @id @default(uuid())
  value Float
  Skill Skill[]

  @@map("skill_values")
}

// ======================================================
// CHARACTER
// ======================================================

model Character {
  id             String           @id @default(uuid())
  nickname       String
  mana           Int
  life           Int
  damage         Int
  nivelAttribute Int              @map("nivel_attribute")
  defense        Int
  magic          Int
  stamina        Int
  lvl            Int
  reputation     Int              @default(0)
  accountId      String           @map("account_id")
  classeId       String           @map("classe_id")
  gold           Int              @default(0)
  status         CharacterStatus?

  account Account @relation(fields: [accountId], references: [id])
  classe  Classe  @relation(fields: [classeId], references: [id])

  progress               CharacterProgress?      @relation("CharacterProgress")
  inventory              Inventory?              @relation("Inventory")
  items                  ItemToCharacter[]
  DropLog                DropLog[]
  boosters               CharacterBooster[]
  store                  Store?
  skillCharacterProgress SkillCharacterProgress?
  characterEquipment     CharacterEquipment?

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  expiresStatusAt DateTime? @map("expires_status_at")

  @@map("characters")
}

// ======================================================
// REMOVEI CharacterEquipments POIS É ANTIGO E INÚTIL
// ======================================================

// ======================================================
// BOOSTERS
// ======================================================

model Booster {
  id          String             @id @default(uuid())
  type        BoostType
  activatedAt DateTime           @map("activated_at")
  expiresAt   DateTime           @map("expires_at")
  isActive    Boolean            @default(false) @map("isActive")
  characters  CharacterBooster[]

  @@map("boosters")
}

model CharacterBooster {
  id          String @id @default(uuid())
  characterId String @map("character_id")
  boosterId   String @map("booster_id")

  booster   Booster   @relation(fields: [boosterId], references: [id])
  character Character @relation(fields: [characterId], references: [id])

  @@map("character_booters")
}

// ======================================================
// MONSTERS / DROPS
// ======================================================

model Monster {
  id          String  @id @default(uuid())
  name        String
  description String?
  lvl         Int
  defense     Int
  damage      Int
  experience  Int
  life        Int
  dodge       Int

  skill       Skill[]
  MonsterDrop MonsterDrop[]
  DropLog     DropLog[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("monsters")
}

model MonsterDrop {
  id        String  @id @default(uuid())
  minGold   Int     @default(5) @map("min_gold")
  maxGold   Int     @default(50) @map("max_gold")
  itemId    String? @map("item_id")
  monsterId String  @unique @map("monster_id")

  Item          Item?             @relation(fields: [itemId], references: [id])
  monster       Monster           @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  possibleItems MonsterDropItem[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("monster_drops")
}

model MonsterDropItem {
  id            String     @id @default(uuid())
  rarity        ItemRarity
  baseChance    Float      @map("base_chance")
  monsterDropId String     @map("monster_drop_id")
  itemId        String     @map("item_id")

  item        Item        @relation(fields: [itemId], references: [id])
  monsterDrop MonsterDrop @relation(fields: [monsterDropId], references: [id])

  minQuantity Int @default(1)
  maxQuantity Int @default(1)

  @@map("monster_drop_items")
}

// ======================================================
// DROP LOG
// ======================================================

model DropLog {
  id          String  @id @default(uuid())
  goldDropped Int     @map("gold_dropped")
  luckApplied Float   @map("luck_applied")
  playerId    String  @map("player_id")
  monsterId   String  @map("monster_id")
  itemId      String? @map("item_id")
  characterId String? @map("character_id")

  Character Character? @relation(fields: [characterId], references: [id])
  Monster   Monster    @relation(fields: [monsterId], references: [id])
  Item      Item?      @relation(fields: [itemId], references: [id])

  itemTemplateIds String[] @map("item_template_ids")
  itemInstanceIds String[] @map("item_instance_ids")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("drop_logs")
}

// ======================================================
// CHARACTER PROGRESS
// ======================================================

model CharacterProgress {
  id               String @id @default(uuid())
  actualExperience Float  @map("actual_experience")
  toNextLvl        Float  @map("to_next_lvl")
  characterId      String @unique @map("character_id")

  character Character @relation("CharacterProgress", fields: [characterId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("characters_progresses")
}

model SkillCharacterProgress {
  id          String    @id @default(uuid())
  characterId String    @unique @map("character_id")
  skillType   Attribute
  level       Int       @default(0)
  experience  Float     @default(0)
  toNextLevel Float

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("skills_character_progress")
}

// ======================================================
// INVENTORY
// ======================================================

model Inventory {
  id          String @id @default(uuid())
  characterId String @unique @map("character_id")

  character Character? @relation("Inventory", fields: [characterId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  baseSlots  Int @default(25)
  extraSlots Int @default(0)

  instances ItemInstance[]
  stacks    ItemStack[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("invetories")
}

// ======================================================
// ITEMS
// ======================================================

model Item {
  id          String  @id @default(uuid())
  name        String
  description String?

  requiredLevel Int @default(1)

  attack  Int?
  defense Int?

  rarity   ItemRarity
  vocation ClasseType?
  itemType ItemType

  critChance  Int?
  dodgeChance Int?
  agility     Int?

  canGiveLife  Boolean @default(false)
  canGiveMana  Boolean @default(false)
  canGiveMagic Boolean @default(false)

  stackCategory String?
  stackable     Boolean @default(false)
  craftable     Boolean @default(false)
  price         Int?
  sellPrice     Int?

  // 🔽 RELAÇÕES INVERSAS (OBRIGATÓRIAS)
  monsterDrops     MonsterDrop[]
  monsterDropItems MonsterDropItem[]
  dropLogs         DropLog[]
  instances        ItemInstance[]
  stacks           ItemStack[]
  storeItems       StoreItem[]
  itemToCharacters ItemToCharacter[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ======================================================
// ITEM INSTANCES (INSTÂNCIAS EQUIPÁVEIS)
// ======================================================

model ItemInstance {
  id          String  @id @default(uuid())
  templateId  String
  inventoryId String?

  serial      String  @unique
  createdFrom String?

  level      Int  @default(1)
  durability Int?

  attackBonus  Int @default(0)
  defenseBonus Int @default(0)
  lifeBonus    Int @default(0)
  manaBonus    Int @default(0)
  magicBonus   Int @default(0)

  rarity   ItemRarity
  equipped Boolean    @default(false)

  template  Item       @relation(fields: [templateId], references: [id])
  inventory Inventory? @relation(fields: [inventoryId], references: [id])

  // 🔽 RELAÇÕES INVERSAS DOS SLOTS
  equippedWeapon CharacterEquipment? @relation("EquipWeapon")
  equippedShield CharacterEquipment? @relation("EquipShield")
  equippedHelmet CharacterEquipment? @relation("EquipHelmet")
  equippedArmor  CharacterEquipment? @relation("EquipArmor")
  equippedLeg    CharacterEquipment? @relation("EquipLeg")
  equippedAmulet CharacterEquipment? @relation("EquipAmulet")
  equippedRing1  CharacterEquipment? @relation("EquipRing1")
  equippedRing2  CharacterEquipment? @relation("EquipRing2")
  equippedBoot   CharacterEquipment? @relation("EquipBoot")
}

// ======================================================
// CHARACTER EQUIPMENTS (SLOTS)
// ======================================================

model CharacterEquipment {
  id          String @id @default(uuid())
  characterId String @unique @map("character_id")

  weaponId String? @unique @map("weapon_id")
  shieldId String? @unique @map("shield_id")
  helmetId String? @unique @map("helmet_id")
  armorId  String? @unique @map("armor_id")
  legId    String? @unique @map("leg_id")
  amuletId String? @unique @map("amulet_id")
  ring1Id  String? @unique @map("ring1_id")
  ring2Id  String? @unique @map("ring2_id")
  bootId   String? @unique @map("boot_id")

  character Character @relation(fields: [characterId], references: [id])

  weapon ItemInstance? @relation("EquipWeapon", fields: [weaponId], references: [id])
  shield ItemInstance? @relation("EquipShield", fields: [shieldId], references: [id])
  helmet ItemInstance? @relation("EquipHelmet", fields: [helmetId], references: [id])
  armor  ItemInstance? @relation("EquipArmor", fields: [armorId], references: [id])
  leg    ItemInstance? @relation("EquipLeg", fields: [legId], references: [id])
  amulet ItemInstance? @relation("EquipAmulet", fields: [amuletId], references: [id])
  ring1  ItemInstance? @relation("EquipRing1", fields: [ring1Id], references: [id])
  ring2  ItemInstance? @relation("EquipRing2", fields: [ring2Id], references: [id])
  boot   ItemInstance? @relation("EquipBoot", fields: [bootId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("character_equipments")
}

// ======================================================
// ITEM STACK
// ======================================================

model ItemStack {
  id          String @id @default(uuid())
  templateId  String @map("template_id")
  inventoryId String @map("inventory_id")
  quantity    Int    @default(1)

  template  Item      @relation(fields: [templateId], references: [id])
  inventory Inventory @relation(fields: [inventoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([templateId, inventoryId], name: "template_inventory_unique")
  @@map("item_stacks")
}

// ======================================================
// STORE
// ======================================================

model Store {
  id          String   @id @default(uuid())
  characterId String   @unique @map("character_id")
  refreshedAt DateTime @default(now()) @map("refreshed_at")

  items     StoreItem[]
  character Character   @relation(fields: [characterId], references: [id])

  @@map("stores")
}

model StoreItem {
  id         String  @id @default(uuid())
  storeId    String  @map("store_id")
  templateId String  @map("template_id")
  price      Int
  purchased  Boolean @default(false)

  store    Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  template Item  @relation(fields: [templateId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("store_items")
}

// ======================================================
// CRAFT
// ======================================================

model CraftRecipe {
  id             String @id @default(uuid())
  resultItemId   String @map("result_item_id")
  requiredStones Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("craft_recipes")
}

model BlacksmithRarityAttempt {
  id             String     @id @default(uuid())
  itemInstanceId String     @map("item_instance_id")
  fromRarity     ItemRarity
  toRarity       ItemRarity
  success        Boolean
  usedStoneId    String?    @map("used_stone_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacksmith_rarity_attempts")
}

// ======================================================
// ITEM TO CHARACTER
// ======================================================

model ItemToCharacter {
  id          String @id @default(uuid())
  characterId String @map("character_id")
  itemId      String @map("item_id")

  player Character @relation(fields: [characterId], references: [id])
  item   Item      @relation(fields: [itemId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("item_to_players")
}
